# Pipeline (Modal containers)
ANTHROPIC_API_KEY=
DEEPGRAM_API_KEY=
SUPABASE_URL=                      # same as NEXT_PUBLIC_SUPABASE_URL
SUPABASE_SERVICE_ROLE_KEY=         # same as web app service_role key

# Web app — copy these into web/.env.local
NEXT_PUBLIC_SUPABASE_URL=          # Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=     # Project Settings → API → anon public
SUPABASE_SERVICE_ROLE_KEY=         # Project Settings → API → service_role (never expose client-side)
MODAL_TOKEN_ID=                    # modal token new → Token ID
MODAL_TOKEN_SECRET=                # modal token new → Token Secret
